<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nền Tảng Ôn Tập Trắc Nghiệm Cao Cấp</title>
    <style>
        /* CSS Variables cho Theme Tối ưu */
        :root {
            --bg-color: #09090e;
            --text-primary: #ffffff;
            --text-secondary: #a1a1aa;
            --accent-1: #6366f1; /* Indigo */
            --accent-2: #a855f7; /* Purple */
            --card-bg: rgba(255, 255, 255, 0.03);
            --card-border: rgba(255, 255, 255, 0.08);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            overflow-x: hidden;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Background 3D Glow Effects */
        .bg-glow {
            position: fixed;
            width: 600px;
            height: 600px;
            background: linear-gradient(to right, var(--accent-1), var(--accent-2));
            border-radius: 50%;
            filter: blur(150px);
            opacity: 0.15;
            z-index: -1;
            top: -200px;
            left: -200px;
            animation: float 10s infinite alternate ease-in-out;
        }

        .bg-glow:nth-child(2) {
            top: auto;
            bottom: -200px;
            right: -200px;
            left: auto;
            animation-delay: -5s;
        }

        @keyframes float {
            0% { transform: translate(0, 0); }
            100% { transform: translate(50px, 50px); }
        }

        /* Header */
        header {
            padding: 2rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--card-border);
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 800;
            background: linear-gradient(to right, #fff, var(--text-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 1px;
        }

        /* Hero Section */
        .hero {
            text-align: center;
            padding: 5rem 2rem 2rem;
        }

        .hero h1 {
            font-size: 3.5rem;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #fff 0%, #a1a1aa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            color: var(--text-secondary);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto 3rem;
            line-height: 1.6;
        }

        /* Grid Môn học / Bài kiểm tra */
        .container {
            width: 90%;
            max-width: 1200px;
            margin: 0 auto 5rem;
        }

        .section-title {
            font-size: 1.8rem;
            margin-bottom: 2rem;
            font-weight: 600;
            position: relative;
            display: inline-block;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 50%;
            height: 3px;
            background: linear-gradient(to right, var(--accent-1), transparent);
            border-radius: 2px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            perspective: 1000px; /* Cần thiết cho hiệu ứng 3D */
        }

        /* Card Design (Glassmorphism + 3D) */
        .card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            padding: 2rem;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            transition: transform 0.1s ease, box-shadow 0.3s ease, border-color 0.3s ease;
            transform-style: preserve-3d;
            backdrop-filter: blur(10px);
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), 
                        rgba(255,255,255,0.06), 
                        transparent 40%);
            z-index: 1;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .card:hover::before {
            opacity: 1;
        }

        .card:hover {
            border-color: rgba(255, 255, 255, 0.2);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 
                        0 0 20px rgba(99, 102, 241, 0.2);
        }

        /* Phần tử bên trong card để tạo hiệu ứng nổi 3D */
        .card-content {
            transform: translateZ(40px); /* Đẩy nội dung lên phía trước theo trục Z */
            z-index: 2;
        }

        .card-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: bold;
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
            margin-bottom: 0.5rem;
        }

        .card h3 {
            font-size: 1.4rem;
            letter-spacing: 0.5px;
        }

        .card p {
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.5;
            flex-grow: 1;
        }

        .card-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid var(--card-border);
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .badge {
            background: rgba(99, 102, 241, 0.1);
            color: #818cf8;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="bg-glow"></div>
    <div class="bg-glow"></div>

    <header>
        <div class="logo">QuizMaster Pro</div>
    </header>

    <main>
        <section class="hero">
            <h1>Hệ thống Ôn tập Chuyên sâu</h1>
            <p>Trải nghiệm kiểm tra trắc nghiệm với giao diện tối giản, tập trung tối đa vào hiệu suất học tập của bạn. Lựa chọn môn học để bắt đầu.</p>
        </section>

        <div class="container">
            <h2 class="section-title">Danh sách bài ôn tập</h2>
            
            <div class="grid">
                <a href="#link-bai-1" class="card">
                    <div class="card-content">
                        <div class="card-icon">{" "}</div>
                        <h3>F7 Giới thiệu CSS</h3>
                        <p>Tổng hợp các câu hỏi trắc nghiệm định nghĩa, phương pháp triển khai và ưu điểm của CSS trong bảo trì web.</p>
                        <div class="card-meta">
                            <span>20 Câu hỏi</span>
                            <span class="badge">Lập trình Web</span>
                        </div>
                    </div>
                </a>

                <a href="#link-bai-2" class="card">
                    <div class="card-content">
                        <div class="card-icon">∑</div>
                        <h3>Toán Cao Cấp</h3>
                        <p>Ôn tập vi tích phân, đại số tuyến tính và các dạng bài tập ứng dụng thực tế.</p>
                        <div class="card-meta">
                            <span>45 Câu hỏi</span>
                            <span class="badge">Đại cương</span>
                        </div>
                    </div>
                </a>

                <a href="#link-bai-3" class="card">
                    <div class="card-content">
                        <div class="card-icon">⚡</div>
                        <h3>Vật Lý Cơ Bản</h3>
                        <p>Kiểm tra kiến thức về động lực học, quang học và điện từ học chuẩn bị cho kỳ thi.</p>
                        <div class="card-meta">
                            <span>30 Câu hỏi</span>
                            <span class="badge">Khoa học</span>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </main>

    <script>
        const cards = document.querySelectorAll('.card');

        cards.forEach(card => {
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;

                // Cập nhật vị trí ánh sáng (glow effect)
                card.style.setProperty('--mouse-x', `${x}px`);
                card.style.setProperty('--mouse-y', `${y}px`);

                // Tính toán góc nghiêng 3D
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                
                const rotateX = ((y - centerY) / centerY) * -10; // Giới hạn nghiêng 10 độ
                const rotateY = ((x - centerX) / centerX) * 10;

                card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
            });

            // Phục hồi trạng thái ban đầu khi chuột rời đi
            card.addEventListener('mouseleave', () => {
                card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
            });
        });
    </script>
</body>
</html>
